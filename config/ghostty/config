# Ghostty configuration
# https://ghostty.org/docs/config

# Clipboard
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = false

# Shell integration (required for ssh-terminfo to work)
shell-integration = zsh

# SSH - automatically copy terminfo to remote servers, fallback to xterm-256color
shell-integration-features = ssh-terminfo,ssh-env

# theme = Mellifluous
theme = Vague

# Window
title = "Ghostty"
window-padding-x = 0
window-padding-y = 0
window-padding-balance = true

unfocused-split-opacity = 0.6

# Hide tab bar and window decorations
window-decoration = none

adjust-cell-height = 10%

# Font
font-family = "ComicCode Nerd Font"
font-style = "Regular"
font-size = 15

# Cursor
cursor-style = "block"
cursor-style-blink = true

# Keybindings
keybind = performable:ctrl+c=copy_to_clipboard
# keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+c=write_screen_file:open
keybind = ctrl+shift+v=paste_from_clipboard
keybind = page_up=scroll_page_up
keybind = page_down=scroll_page_down
macos-option-as-alt = true

link-url = true
